"""Thin wrapper for the lshell CLI."""

import os
import sys

TOPDIR = os.path.abspath(os.path.join(os.path.dirname(__file__), ".."))
if TOPDIR not in sys.path:
    sys.path.insert(0, TOPDIR)

from lshell.cli import main


if __name__ == "__main__":
    main()
